<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Note: For Android please see also Platforms\Android\Resources\values\colors.xml -->

	<Color x:Key="Base100">#1E1F29</Color>
	<Color x:Key="Base200">#1A1B24</Color>
	<Color x:Key="Base300">#17181F</Color>

	<Color x:Key="BaseContent">#F8F8F2</Color>

	<Color x:Key="Neutral">#44475A</Color>
	<Color x:Key="NeutralContent">#E6E6E6</Color>

	<Color x:Key="Primary">#FF79C6</Color>
	<Color x:Key="PrimaryContent">#3A0F2A</Color>

	<Color x:Key="Secondary">#BD93F9</Color>
	<Color x:Key="SecondaryContent">#2E1F45</Color>

	<Color x:Key="Accent">#F1FA8C</Color>
	<Color x:Key="AccentContent">#3A3F1A</Color>

	<Color x:Key="Info">#8BE9FD</Color>
	<Color x:Key="InfoContent">#1A3B45</Color>

	<Color x:Key="Success">#50FA7B</Color>
	<Color x:Key="SuccessContent">#0F3D1F</Color>

	<Color x:Key="Warning">#F1FA8C</Color>
	<Color x:Key="WarningContent">#3A3F1A</Color>

	<Color x:Key="Error">#FF5555</Color>
	<Color x:Key="ErrorContent">#3F0F0F</Color>
</ResourceDictionary>
<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="App_Compras_MAUI.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:App_Compras_MAUI"
    xmlns:view="clr-namespace:App_Compras_MAUI.View"
    Title="App_Compras_MAUI">

    <Shell.Style>
        <Style TargetType="Shell">
            <Setter Property="Shell.NavBarIsVisible" Value="False" />
        </Style>
    </Shell.Style>

    <ShellContent
        Title="Listagem"
        ContentTemplate="{DataTemplate view:List}"
        Route="List" />

</Shell>

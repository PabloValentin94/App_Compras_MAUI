<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:App_Compras_MAUI"
             x:Class="App_Compras_MAUI.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style TargetType="Label" x:Key="lbl_primary">
                <Setter Property="FontSize" Value="35" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="HorizontalTextAlignment" Value="Center" />
                <Setter Property="TextColor" Value="{ DynamicResource Primary }" />
            </Style>

            <Style TargetType="Label" x:Key="lbl_form">
                <Setter Property="FontSize" Value="Medium" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="HorizontalTextAlignment" Value="Start"/>
            </Style>

            <Style TargetType="Button" x:Key="btn_primary">
                <Setter Property="BackgroundColor" Value="{ DynamicResource Primary }" />
                <Setter Property="BorderColor" Value="{ DynamicResource PrimaryContent }" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{ DynamicResource PrimaryContent }" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
